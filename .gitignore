# ==============================================================
# PestGuard AI — .gitignore
# ==============================================================

# ── Dependencies ──
node_modules/

# ── Build output ──
dist/
dist-ssr/

# ── Environment variables ──
.env
.env.local
.env.production.local
*.local
backend/.env

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
backend/server.log
backend/uvicorn.log
backend/uvicorn.err.log

# ── Python ──
backend/venv/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── Database (runtime) ──
backend/*.db

# ── Model weights (too large for git) ──
# Only warehouse_pest.pt (custom-trained) should be committed.
backend/*.pt
!backend/warehouse_pest.pt

# ── Training data & artifacts ──
backend/dataset/
backend/dataset_merged/
backend/runs/

# ── Runtime artifacts ──
backend/snapshots/

# ── OS / IDE ──
.DS_Store
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vscode/*
!.vscode/extensions.json
.idea/

# ── Development tool caches ──
.vercel/
.claude/

# ── Screenshots (development artifacts, don't commit) ──
Screenshot*.png
