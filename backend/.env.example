# Smart Warehouse — Environment Configuration
# Copy this file to .env and customize values

# ── Core ─────────────────────────────────────────────────────────────────────
# Backend secret key (gunakan: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=pestguard-dev-key-CHANGE-IN-PRODUCTION

# SQLite database path (relative to backend/)
DB_PATH=warehouse.db

# Default detection confidence threshold (0-100, recommended: 50-65)
DEFAULT_THRESHOLD=50

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Dapatkan API key GRATIS di: https://aistudio.google.com/app/apikey
# Model: gemini-2.0-flash (cepat & akurat untuk RAG pattern)
GEMINI_API_KEY=

# ── Telegram Bot Alert ───────────────────────────────────────────────────────
# Cara setup Telegram Bot:
#   1. Cari @BotFather di Telegram
#   2. Kirim /newbot, ikuti instruksi → dapat BOT_TOKEN
#   3. Kirim pesan apapun ke bot kamu
#   4. Buka: https://api.telegram.org/bot<TOKEN>/getUpdates
#   5. Cari "chat":{"id": ...} → itu CHAT_ID kamu
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Roboflow (Training Dataset) ───────────────────────────────────────────────
# Hanya dibutuhkan jika kamu ingin re-download dataset training
# Dapatkan di: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=
